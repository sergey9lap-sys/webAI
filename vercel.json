{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/thanks",
      "destination": "/thanks/index.html"
    },
    {
      "source": "/thanks/",
      "destination": "/thanks/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
